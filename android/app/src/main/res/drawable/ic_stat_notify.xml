<?xml version="1.0" encoding="utf-8"?>
<!-- Status-bar / notification small icon. Must be a flat, single-colour
     silhouette on a transparent background — Android always re-renders this
     as a solid alpha mask regardless of the fill colour, so a detailed
     full-colour icon (what R.mipmap.ic_launcher_foreground used to be used
     for) comes out as an unrecognisable blob. A simple checkmark reads
     cleanly at 24dp and matches the to-do/planner brand. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M9,16.17L4.83,12l-1.42,1.41L9,19 21,7l-1.41,-1.41z"/>
</vector>
