<?xml version="1.0" encoding="utf-8"?>
<!-- InkList adaptive-icon background: the app's actual hero brand gradient
     (coral -> rose -> violet, same stops as AppColors.heroGradient), full
     bleed so it reads correctly whichever mask shape the launcher applies. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path android:pathData="M0,0 H108 V108 H0 Z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                android:startX="0" android:startY="0"
                android:endX="108" android:endY="108">
                <item android:offset="0" android:color="#FFF07E5C"/>
                <item android:offset="0.5" android:color="#FFEF6B7D"/>
                <item android:offset="1" android:color="#FF7C6BD6"/>
            </gradient>
        </aapt:attr>
    </path>
</vector>
