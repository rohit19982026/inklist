<?xml version="1.0" encoding="utf-8"?>
<!-- InkList app-icon foreground (adaptive icon, 108x108 canvas). A vector
     recreation of the brand mark: a broken gradient ring that flows into a
     bold checkmark, motion "speed lines" entering from the left, and two
     AI sparkles top-right. The purple→blue→teal diagonal gradient matches
     the source artwork (purple top-left, teal bottom-right). Vector so it
     stays crisp at every launcher size with no per-density rasters. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Ring: nearly-full circle, open on the left where the motion lines enter -->
    <path
        android:pathData="M26.97,35.07 A33,33 0 1 1 26.97,72.93"
        android:strokeWidth="11"
        android:strokeLineCap="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient android:type="linear"
                android:startX="18" android:startY="18"
                android:endX="90" android:endY="92">
                <item android:offset="0" android:color="#FF7C3AED"/>
                <item android:offset="0.5" android:color="#FF2563EB"/>
                <item android:offset="1" android:color="#FF10B981"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Checkmark -->
    <path
        android:pathData="M42,55 L52,66 L75,40"
        android:strokeWidth="11"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient android:type="linear"
                android:startX="42" android:startY="66"
                android:endX="75" android:endY="40">
                <item android:offset="0" android:color="#FF4F46E5"/>
                <item android:offset="1" android:color="#FF14B8A6"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Motion "speed" lines entering from the left -->
    <path
        android:pathData="M24,45 L37,45 M15,55 L38,55 M22,65 L36,65"
        android:strokeWidth="7"
        android:strokeLineCap="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient android:type="linear"
                android:startX="15" android:startY="45"
                android:endX="40" android:endY="65">
                <item android:offset="0" android:color="#FF7C3AED"/>
                <item android:offset="1" android:color="#FF4F46E5"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- AI sparkles (top-right) -->
    <path
        android:fillColor="#FF10B981"
        android:pathData="M84,18 Q84,26 92,26 Q84,26 84,34 Q84,26 76,26 Q84,26 84,18 Z"/>
    <path
        android:fillColor="#FF14B8A6"
        android:pathData="M94,35 Q94,39.5 99,39.5 Q94,39.5 94,44 Q94,39.5 89,39.5 Q94,39.5 94,35 Z"/>

    <!-- "AI" wordmark -->
    <path
        android:pathData="M80,62 L84.5,50 L89,62 M81.6,57.5 L87.4,57.5"
        android:strokeWidth="2.6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:strokeColor="#FF0E9AA0"
        android:fillColor="#00000000"/>
    <path
        android:pathData="M93,50 L93,62"
        android:strokeWidth="2.6"
        android:strokeLineCap="round"
        android:strokeColor="#FF0E9AA0"
        android:fillColor="#00000000"/>
</vector>
